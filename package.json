{
  "name": "role-planner",
  "version": "1.4.1",
  "description": "Work Roles & Responsibilities Planner with Microsoft 365 integration",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.2",
    "axios": "^1.7.9",
    "electron-store": "^8.2.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.w1corp.roleplanner",
    "productName": "Role Planner",
    "copyright": "Copyright © 2025 Eddie Warren / Warren Dev",
    "directories": { "output": "dist" },
    "win": {
      "target": ["nsis"],
      "icon": "src/assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "src/assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "author": {
    "name": "Eddie Warren",
    "company": "WARREN C.H.E"
  },
  "license": "MIT",
  "copyright": "Copyright © 2025 Eddie Warren / WARREN C.H.E"
}
